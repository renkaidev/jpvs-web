<a aria-label="Contactar por WhatsApp" target="_blank" rel="noopener noreferrer" class="fixed bottom-6 right-6 md:bottom-12 md:right-12 bg-[#25D366] text-white p-4 rounded-full shadow-[0_4px_20px_rgba(37,211,102,0.4)] hover:scale-110 hover:shadow-[0_4px_30px_rgba(37,211,102,0.6)] transition-all z-50 flex items-center justify-center group gs-fab" href="https://wa.me/56975365503">
  <span class="material-symbols-outlined text-[32px]">chat</span>
  <!-- Tooltip -->
  <span class="absolute right-full mr-4 bg-surface-container-high text-on-surface px-4 py-2 rounded-lg font-label-sm whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity border border-white/10 pointer-events-none">
    Contáctenos
  </span>
</a>

<script>
  import gsap from "gsap";
  
  // Make the FAB pop in after a delay
  gsap.from(".gs-fab", {
    scale: 0,
    opacity: 0,
    duration: 0.6,
    delay: 2,
    ease: "back.out(2)"
  });
</script>
