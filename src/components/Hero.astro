---
---
<section class="relative pt-section-gap-mobile md:pt-section-gap-desktop pb-section-gap-mobile md:pb-section-gap-desktop overflow-hidden border-b border-white/10" id="hero">
  <!-- Background Glow -->
  <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-96 h-96 bg-secondary/10 rounded-full blur-[100px] pointer-events-none hero-glow"></div>
  
  <div class="max-w-[1200px] mx-auto px-grid-gutter grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10">
    <div class="flex flex-col items-start gap-8 hero-content">
      <div>
        <h1 class="font-display-lg text-display-lg text-on-surface mb-4">JPVS</h1>
        <p class="font-headline-lg text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-secondary uppercase tracking-wider">Servicio Garantizado</p>
      </div>
      
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-lg">
        Gasfitería, soldadura, electricidad básica, construcción en general y más en Cauquenes y alrededores.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a href="https://wa.me/56975365503" class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white px-8 py-4 rounded-xl font-headline-md text-body-lg font-bold shadow-[0_0_20px_rgba(37,211,102,0.3)] hover:shadow-[0_0_30px_rgba(37,211,102,0.5)] transition-all">
          <span class="material-symbols-outlined">chat</span>
          WhatsApp
        </a>
        <a href="tel:+56975365503" class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-secondary text-secondary px-8 py-4 rounded-xl font-headline-md text-body-lg font-bold hover:bg-secondary/10 transition-colors">
          <span class="material-symbols-outlined">call</span>
          Llamar
        </a>
      </div>
    </div>
    
    <div class="relative w-full h-[500px] rounded-[3rem] overflow-hidden border-4 border-white/20 shadow-[0_0_30px_rgba(185,199,228,0.2)] hero-image-container bg-surface-container flex items-center justify-center p-4 transition-colors">
      <img src="/assets/JPVS.jpg" alt="JPVS Professional" class="w-full h-full object-contain hero-img" />
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  
  gsap.from(".hero-content > *", {
    y: 50,
    opacity: 0,
    duration: 1,
    stagger: 0.2,
    ease: "power3.out",
    delay: 0.5
  });
  
  gsap.from(".hero-image-container", {
    x: 50,
    opacity: 0,
    duration: 1.2,
    ease: "power3.out",
    delay: 0.8
  });

  const heroImg = document.querySelector(".hero-img");
  const heroContainer = document.querySelector(".hero-image-container");
  
  if (heroImg && heroContainer) {
    heroContainer.addEventListener("mouseenter", () => {
      gsap.to(heroImg, { scale: 1.1, duration: 0.5, ease: "power2.out" });
      gsap.to(heroContainer, { borderColor: "rgba(255,255,255,0.5)", duration: 0.5 });
    });
    
    heroContainer.addEventListener("mouseleave", () => {
      gsap.to(heroImg, { scale: 1, duration: 0.5, ease: "power2.out" });
      gsap.to(heroContainer, { borderColor: "rgba(255,255,255,0.2)", duration: 0.5 });
    });
  }
</script>
