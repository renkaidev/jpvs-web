---
<section class="py-section-gap-mobile md:py-section-gap-desktop bg-transparent border-b border-white/10 overflow-hidden" id="por-que">
  <div class="max-w-[1200px] mx-auto px-grid-gutter text-center">
    <h2 class="font-headline-lg text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-on-surface mb-12 gs-why-header">¿Por qué elegirme?</h2>
    
    <div class="relative max-w-2xl mx-auto gs-carousel-container group/carousel">
      <!-- Prev Button -->
      <button class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-12 h-12 flex items-center justify-center bg-secondary text-on-secondary rounded-full hover:bg-secondary-fixed transition-transform hover:scale-110 shadow-lg -translate-x-1/2 md:-translate-x-6" id="carousel-prev" aria-label="Anterior">
        <span class="material-symbols-outlined text-[28px]">chevron_left</span>
      </button>
      
      <!-- Carousel Track Container -->
      <div class="overflow-hidden px-4 py-8 -my-8">
        <!-- Carousel Track -->
        <div class="flex" id="carousel-track">
          
          <!-- Item 1 -->
          <div class="w-full flex-shrink-0 px-4 carousel-item">
            <div class="flex flex-col items-center justify-center p-8 h-full bg-surface-container rounded-2xl border border-white/5 hover:-translate-y-3 hover:border-secondary/30 hover:shadow-[0_15px_40px_-10px_rgba(74,142,255,0.2)] transition-all duration-300 group cursor-grab active:cursor-grabbing">
              <div class="w-24 h-24 rounded-full bg-secondary/10 flex items-center justify-center mb-6 text-secondary group-hover:scale-110 group-hover:bg-secondary group-hover:text-on-secondary transition-all duration-500 shadow-[inset_0_0_20px_rgba(0,0,0,0.2)]">
                <span class="material-symbols-outlined text-[48px]">schedule</span>
              </div>
              <p class="font-headline-md text-2xl font-bold text-on-surface">Puntualidad</p>
            </div>
          </div>
          
          <!-- Item 2 -->
          <div class="w-full flex-shrink-0 px-4 carousel-item">
            <div class="flex flex-col items-center justify-center p-8 h-full bg-surface-container rounded-2xl border border-white/5 hover:-translate-y-3 hover:border-secondary/30 hover:shadow-[0_15px_40px_-10px_rgba(74,142,255,0.2)] transition-all duration-300 group cursor-grab active:cursor-grabbing">
              <div class="w-24 h-24 rounded-full bg-secondary/10 flex items-center justify-center mb-6 text-secondary group-hover:scale-110 group-hover:bg-secondary group-hover:text-on-secondary transition-all duration-500 shadow-[inset_0_0_20px_rgba(0,0,0,0.2)]">
                <span class="material-symbols-outlined text-[48px]">cleaning_services</span>
              </div>
              <p class="font-headline-md text-2xl font-bold text-on-surface">Limpieza</p>
            </div>
          </div>
          
          <!-- Item 3 -->
          <div class="w-full flex-shrink-0 px-4 carousel-item">
            <div class="flex flex-col items-center justify-center p-8 h-full bg-surface-container rounded-2xl border border-white/5 hover:-translate-y-3 hover:border-secondary/30 hover:shadow-[0_15px_40px_-10px_rgba(74,142,255,0.2)] transition-all duration-300 group cursor-grab active:cursor-grabbing">
              <div class="w-24 h-24 rounded-full bg-secondary/10 flex items-center justify-center mb-6 text-secondary group-hover:scale-110 group-hover:bg-secondary group-hover:text-on-secondary transition-all duration-500 shadow-[inset_0_0_20px_rgba(0,0,0,0.2)]">
                <span class="material-symbols-outlined text-[48px]">verified_user</span>
              </div>
              <p class="font-headline-md text-2xl font-bold text-on-surface">Responsabilidad</p>
            </div>
          </div>
          
          <!-- Item 4 -->
          <div class="w-full flex-shrink-0 px-4 carousel-item">
            <div class="flex flex-col items-center justify-center p-8 h-full bg-surface-container rounded-2xl border border-white/5 hover:-translate-y-3 hover:border-secondary/30 hover:shadow-[0_15px_40px_-10px_rgba(74,142,255,0.2)] transition-all duration-300 group cursor-grab active:cursor-grabbing">
              <div class="w-24 h-24 rounded-full bg-secondary/10 flex items-center justify-center mb-6 text-secondary group-hover:scale-110 group-hover:bg-secondary group-hover:text-on-secondary transition-all duration-500 shadow-[inset_0_0_20px_rgba(0,0,0,0.2)]">
                <span class="material-symbols-outlined text-[48px]">speed</span>
              </div>
              <p class="font-headline-md text-2xl font-bold text-on-surface">Rapidez</p>
            </div>
          </div>
          
          <!-- Item 5 -->
          <div class="w-full flex-shrink-0 px-4 carousel-item">
            <div class="flex flex-col items-center justify-center p-8 h-full bg-surface-container rounded-2xl border border-white/5 hover:-translate-y-3 hover:border-secondary/30 hover:shadow-[0_15px_40px_-10px_rgba(74,142,255,0.2)] transition-all duration-300 group cursor-grab active:cursor-grabbing">
              <div class="w-24 h-24 rounded-full bg-secondary/10 flex items-center justify-center mb-6 text-secondary group-hover:scale-110 group-hover:bg-secondary group-hover:text-on-secondary transition-all duration-500 shadow-[inset_0_0_20px_rgba(0,0,0,0.2)]">
                <span class="material-symbols-outlined text-[48px]">visibility</span>
              </div>
              <p class="font-headline-md text-2xl font-bold text-on-surface">Transparencia</p>
            </div>
          </div>
          
          <!-- Item 6 -->
          <div class="w-full flex-shrink-0 px-4 carousel-item">
            <div class="flex flex-col items-center justify-center p-8 h-full bg-surface-container rounded-2xl border border-white/5 hover:-translate-y-3 hover:border-secondary/30 hover:shadow-[0_15px_40px_-10px_rgba(74,142,255,0.2)] transition-all duration-300 group cursor-grab active:cursor-grabbing">
              <div class="w-24 h-24 rounded-full bg-secondary/10 flex items-center justify-center mb-6 text-secondary group-hover:scale-110 group-hover:bg-secondary group-hover:text-on-secondary transition-all duration-500 shadow-[inset_0_0_20px_rgba(0,0,0,0.2)]">
                <span class="material-symbols-outlined text-[48px]">precision_manufacturing</span>
              </div>
              <p class="font-headline-md text-2xl font-bold text-on-surface">Prolijidad</p>
            </div>
          </div>
          
        </div>
      </div>
      
      <!-- Next Button -->
      <button class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-12 h-12 flex items-center justify-center bg-secondary text-on-secondary rounded-full hover:bg-secondary-fixed transition-transform hover:scale-110 shadow-lg translate-x-1/2" id="carousel-next" aria-label="Siguiente">
        <span class="material-symbols-outlined text-[28px]">chevron_right</span>
      </button>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);
  
  gsap.from(".gs-why-header", {
    scrollTrigger: {
      trigger: "#por-que",
      start: "top 85%",
    },
    y: 30,
    opacity: 0,
    duration: 1,
    ease: "power3.out"
  });

  // Carousel Logic
  const track = document.getElementById('carousel-track');
  const items = document.querySelectorAll('.carousel-item');
  const prevBtn = document.getElementById('carousel-prev');
  const nextBtn = document.getElementById('carousel-next');
  const container = document.querySelector('.gs-carousel-container');
  
  if (track && items.length > 0) {
    let currentIndex = 0;
    
    function getItemsPerView() {
      return 1;
    }
    
    let itemsPerView = getItemsPerView();
    let maxIndex = Math.max(0, items.length - itemsPerView);
    
    window.addEventListener('resize', () => {
      itemsPerView = getItemsPerView();
      maxIndex = Math.max(0, items.length - itemsPerView);
      if (currentIndex > maxIndex) currentIndex = maxIndex;
      updateCarousel(0); // instant update on resize
    });
    
    function updateCarousel(duration = 0.5) {
      const itemWidth = (items[0] as HTMLElement).offsetWidth;
      gsap.to(track, {
        x: -(currentIndex * itemWidth),
        duration: duration,
        ease: "power2.inOut"
      });
    }
    
    function next() {
      currentIndex++;
      if (currentIndex > maxIndex) {
        currentIndex = 0; // loop back to start
      }
      updateCarousel();
    }
    
    function prev() {
      currentIndex--;
      if (currentIndex < 0) {
        currentIndex = maxIndex; // loop to end
      }
      updateCarousel();
    }
    
    prevBtn?.addEventListener('click', () => {
      prev();
      resetAutoPlay();
    });
    
    nextBtn?.addEventListener('click', () => {
      next();
      resetAutoPlay();
    });
    
    // Autoplay every 2 seconds
    let autoPlayTimer = setInterval(next, 2000);
    
    function resetAutoPlay() {
      clearInterval(autoPlayTimer);
      autoPlayTimer = setInterval(next, 2000);
    }
    
    // Pause on hover
    container?.addEventListener('mouseenter', () => clearInterval(autoPlayTimer));
    container?.addEventListener('mouseleave', () => resetAutoPlay());
    
    // Animate entire carousel entrance
    gsap.from(".gs-carousel-container", {
      scrollTrigger: {
        trigger: "#por-que",
        start: "top 80%",
      },
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: "power3.out"
    });
  }
</script>
